<%- include('header') %>

<section class="hero-gradient relative py-24 px-6 text-center overflow-hidden">
  <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 30% 40%, #a855f7 0%, transparent 50%), radial-gradient(circle at 70% 60%, #d4a517 0%, transparent 50%);"></div>
  <div class="relative max-w-4xl mx-auto">
    <h1 class="font-display text-5xl md:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-r from-gold-400 via-prism-400 to-gold-400 prismatic-glow leading-tight">
      The Prismatic Soul
    </h1>
    <p class="mt-6 text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
      A multiverse-spanning campaign where heroes cross between worlds, guided by ancient keepers
      and hunted by those who would consume the very light of creation.
    </p>
    <div class="mt-10 flex justify-center gap-4">
      <a href="/characters" class="px-6 py-3 bg-gradient-to-r from-prism-600 to-prism-500 rounded-lg font-semibold text-white hover:from-prism-500 hover:to-prism-400 transition shadow-lg shadow-prism-600/30">Meet the Cast</a>
      <a href="/worlds" class="px-6 py-3 border border-gold-500/40 rounded-lg font-semibold text-gold-400 hover:bg-gold-500/10 transition">Explore Worlds</a>
    </div>
  </div>
</section>

<section class="max-w-7xl mx-auto px-6 py-16">
  <div class="text-center mb-12">
    <h2 class="font-display text-3xl font-bold text-gold-400">Key Figures</h2>
    <div class="gold-line w-32 mx-auto mt-3"></div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% characters.filter(c => c.imageKey).slice(0, 6).forEach(c => { %>
    <div class="glass rounded-xl overflow-hidden card-hover">
      <div class="h-56 overflow-hidden">
        <img src="<%= assetBase %>/images/<%= c.imageKey %>" alt="<%= c.name %>"
             class="w-full h-full object-cover object-top" loading="lazy"/>
      </div>
      <div class="p-5">
        <h3 class="font-display text-lg font-bold text-gold-400"><%= c.name %></h3>
        <p class="text-prism-400 text-sm mt-1"><%= c.title || '' %></p>
        <p class="text-gray-400 text-sm mt-2 line-clamp-3"><%= c.description || c.concept || '' %></p>
      </div>
    </div>
    <% }) %>
  </div>

  <div class="text-center mt-10">
    <a href="/characters" class="text-gold-400 hover:text-gold-500 font-semibold transition">View All Characters &rarr;</a>
  </div>
</section>

<section class="max-w-7xl mx-auto px-6 pb-16">
  <div class="text-center mb-12">
    <h2 class="font-display text-3xl font-bold text-gold-400">The Multiverse</h2>
    <div class="gold-line w-32 mx-auto mt-3"></div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <% worlds.forEach(w => { %>
    <div class="glass rounded-xl p-6 card-hover">
      <h3 class="font-display text-xl font-bold text-prism-400"><%= w.name %></h3>
      <% if (w.splendorName) { %>
        <p class="text-gold-500 text-xs mt-1 uppercase tracking-widest">Splendor known as: <%= w.splendorName %></p>
      <% } %>
      <p class="text-gray-400 text-sm mt-3 leading-relaxed"><%= w.description || '' %></p>
      <% if (w.status) { %>
        <span class="inline-block mt-3 text-xs px-3 py-1 rounded-full border border-prism-500/30 text-prism-400"><%= w.status %></span>
      <% } %>
    </div>
    <% }) %>
  </div>
</section>

<%- include('footer') %>

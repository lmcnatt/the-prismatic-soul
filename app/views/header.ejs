<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>The Prismatic Soul</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            void:    { 900: '#0a0a0f', 800: '#12121c', 700: '#1a1a2e' },
            gold:    { 400: '#f0c040', 500: '#d4a517', 600: '#b8860b' },
            prism:   { 400: '#c084fc', 500: '#a855f7', 600: '#9333ea' },
            crimson: { 500: '#dc2626', 600: '#b91c1c' },
          },
          fontFamily: { display: ['"Cinzel"', 'serif'], body: ['"Inter"', 'sans-serif'] },
        }
      }
    }
  </script>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    body { font-family: 'Inter', sans-serif; }
    .font-display { font-family: 'Cinzel', serif; }
    .glass { background: rgba(10,10,15,0.7); backdrop-filter: blur(12px); border: 1px solid rgba(240,192,64,0.15); }
    .prismatic-glow { text-shadow: 0 0 30px rgba(168,85,247,0.5), 0 0 60px rgba(240,192,64,0.3); }
    .card-hover { transition: transform 0.3s, box-shadow 0.3s; }
    .card-hover:hover { transform: translateY(-6px); box-shadow: 0 12px 40px rgba(168,85,247,0.25); }
    .hero-gradient { background: linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 40%, #2d1b4e 70%, #0a0a0f 100%); }
    .gold-line { background: linear-gradient(90deg, transparent, #d4a517, transparent); height: 1px; }
  </style>
</head>
<body class="bg-void-900 text-gray-200 min-h-screen flex flex-col">

<nav class="glass sticky top-0 z-50 px-6 py-3">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <span class="text-2xl">&#x1F48E;</span>
      <span class="font-display text-gold-400 text-lg font-bold tracking-wide group-hover:text-gold-500 transition">The Prismatic Soul</span>
    </a>
    <div class="flex gap-6 text-sm font-medium">
      <a href="/" class="text-gray-300 hover:text-gold-400 transition">Home</a>
      <a href="/characters" class="text-gray-300 hover:text-gold-400 transition">Characters</a>
      <a href="/worlds" class="text-gray-300 hover:text-gold-400 transition">Worlds</a>
      <a href="/lore" class="text-gray-300 hover:text-gold-400 transition">Lore</a>
    </div>
  </div>
</nav>

<main class="flex-1">

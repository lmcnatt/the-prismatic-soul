<%- include('header') %>

<section class="max-w-7xl mx-auto px-6 py-16">
  <div class="text-center mb-12">
    <h1 class="font-display text-4xl font-black text-gold-400">The Multiverse</h1>
    <p class="text-gray-400 mt-3">Each pool in the Woods Between Worlds leads to a different reality, each with its own expression of Splendor.</p>
    <div class="gold-line w-32 mx-auto mt-4"></div>
  </div>

  <div class="grid grid-cols-1 gap-6">
    <% worlds.forEach(w => { %>
    <div class="glass rounded-xl p-8 card-hover">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <h2 class="font-display text-2xl font-bold text-prism-400"><%= w.name %></h2>
          <% if (w.splendorName) { %>
            <p class="text-gold-500 text-xs mt-1 uppercase tracking-widest">The Splendor is known as: <%= w.splendorName %></p>
          <% } %>
        </div>
        <% if (w.status) { %>
          <span class="text-xs px-3 py-1 rounded-full border border-prism-500/30 text-prism-400"><%= w.status %></span>
        <% } %>
      </div>
      <p class="text-gray-400 mt-4 leading-relaxed"><%= w.description || '' %></p>
      <% if (w.features && w.features.length) { %>
        <div class="mt-4 flex flex-wrap gap-2">
          <% w.features.forEach(f => { %>
            <span class="text-xs px-2 py-1 rounded bg-void-700 text-gray-400 border border-gray-700"><%= f %></span>
          <% }) %>
        </div>
      <% } %>
      <% if (w.atmosphere) { %>
        <p class="text-gray-500 text-sm mt-3 italic">Atmosphere: <%= w.atmosphere %></p>
      <% } %>
    </div>
    <% }) %>
  </div>
</section>

<%- include('footer') %>
